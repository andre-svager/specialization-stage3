# ========== Basic Configuration ==========

environment = "staging"

# Use "production" for production environment
# Note: Some resources behavior changes with environment (e.g., skip_final_snapshot for RDS)

aws_region = "us-east-1"

# ========== Cluster Configuration ==========

cluster_name = "fiap-stage3-eks"

kubernetes_version = "1.29"

# ========== EKS Node Group Configuration ==========

node_instance_type = "t3.medium"

node_desired_size = 2
node_min_size     = 1
node_max_size     = 2

# ========== Network Configuration ==========

vpc_cidr = "10.1.0.0/16"

availability_zones = ["us-east-1a", "us-east-1b"]

# ========== RDS PostgreSQL Configuration ==========

postgres_version = "13"

rds_instance_class = "db.t3.small"

rds_allocated_storage = 20

# IMPORTANT: Replace with secure passwords!
# For production, use AWS Secrets Manager to manage passwords
rds_username = "postgres"
rds_password = "ChangeMe!Secure123"  # Change this to a secure password

rds_multi_az = false

rds_backup_retention_days = 7

# ========== ElastiCache Redis Configuration ==========

redis_version = "7.0"

redis_node_type = "cache.t3.micro"

redis_num_nodes = 1

# ========== DynamoDB Configuration ==========

dynamodb_billing_mode = "PAY_PER_REQUEST"

# For PROVISIONED mode, uncomment and set:
# dynamodb_min_capacity = 5
# dynamodb_max_capacity = 40

# ========== SQS Configuration ==========

use_fifo_queues = true

sqs_visibility_timeout = 300

sqs_message_retention_period = 345600  # 4 days

sqs_receive_wait_time = 20

# ========== ECR Configuration ==========

ecr_images_to_keep = 10
